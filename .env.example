# ── Required for all runs ──────────────────────────────────────────────────────
# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# LangFuse observability (https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Jira (optional) ───────────────────────────────────────────────────────────
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_USER_EMAIL=you@yourorg.com
JIRA_API_TOKEN=your-jira-api-token

# ── Slack (optional) ──────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...

# ── GitHub (optional) ─────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ── Google — Calendar, Drive, Gmail (optional, all share one OAuth client) ────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_PROJECT_ID=your-project-id

# ── Skill fetch limit (optional) ──────────────────────────────────────────────
# Maximum ActivityItems returned per skill per run (oldest dropped when exceeded)
SKILL_FETCH_LIMIT=100
