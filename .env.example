# ── Vertex AI — Claude (required) ─────────────────────────────────────────────
# The Google Cloud project where Claude is deployed on Vertex AI.
# Authentication uses Application Default Credentials (ADC) — no API key needed.
# Local dev: run `gcloud auth application-default login` once.
# GKE / Cloud Run: attach a service account with the Vertex AI User role.
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_REGION=us-east5

# Claude model deployed in your Vertex AI project.
CLAUDE_MODEL=claude-sonnet-4-6

# ── Agent Limits ─────────────────────────────────────────────────────────────
# Maximum number of agent loop turns (Claude tool_use cycles) per report.
MAX_AGENT_TURNS=50

# ── Jira (optional) ───────────────────────────────────────────────────────────
# MCP server: @sooperset/mcp-atlassian
# Create an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_USER_EMAIL=you@yourorg.com
JIRA_API_TOKEN=your-jira-api-token

# ── Slack (optional) ──────────────────────────────────────────────────────────
# MCP server: korotovsky/slack-mcp-server (no workspace admin approval required)
# Extract tokens from your browser session — no app registration needed.
# Automated: uv run python -m status_report.auth.slack --extract
# Manual: open Slack in a browser → DevTools → Application → Cookies (xoxd) + localStorage (xoxc)
SLACK_MCP_XOXC_TOKEN=xoxc-...
SLACK_MCP_XOXD_TOKEN=xoxd-...
# Playwright fallback (one-time login): uv run python -m status_report.auth.slack --login
# Session stored at ~/.status-report/playwright-state.json (auto-detected at runtime)

# ── GitHub (optional) ─────────────────────────────────────────────────────────
# MCP server: ghcr.io/github/github-mcp-server (official Go binary, run via Docker)
# Requires Docker on the host. Create a Personal Access Token at:
# https://github.com/settings/tokens — scopes: repo (read), read:org
GITHUB_TOKEN=ghp_...

# ── Google — Calendar, Drive, Gmail (optional, all share one OAuth client) ────
# MCP server: taylorwilsdon/google_workspace_mcp (run via uvx workspace-mcp)
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Application type: Desktop app | Enable: Calendar API, Drive API, Gmail API
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_PROJECT_ID=your-gcp-project-id
